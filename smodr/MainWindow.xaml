<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="smodr.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smodr"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="smodr — Smodcast Player">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Custom Title Bar ═══ -->
        <Grid x:Name="AppTitleBar" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="138"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="1"
                   Source="ms-appx:///Assets/StoreLogo.png"
                   Width="16" Height="16"
                   VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2"
                       Text="smodr"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
        </Grid>

        <!-- ═══ Content Area ═══ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <Grid Grid.Row="0" Padding="24,12,24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="2">
                    <TextBlock Text="Smodcast Episodes"
                               Style="{ThemeResource TitleTextBlockStyle}"/>
                    <TextBlock Text="Kevin Smith &amp; Scott Mosier"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Top">
                    <Button x:Name="SettingsButton"
                            Width="32" Height="32" Padding="0"
                            Background="Transparent" BorderBrush="Transparent"
                            ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Cache Information"
                                               Click="CacheInfoMenuItem_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE946;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Clear Cache"
                                               Click="ClearCacheMenuItem_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="Force Refresh"
                                               Click="ForceRefreshMenuItem_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE72C;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button x:Name="RefreshButton"
                            Click="RefreshButton_Click"
                            Width="32" Height="32" Padding="0"
                            Background="Transparent" BorderBrush="Transparent"
                            ToolTipService.ToolTip="Refresh episodes">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Loading & Episodes -->
            <Grid Grid.Row="1">
                <!-- Loading indicator -->
                <StackPanel x:Name="LoadingPanel"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Visible"
                           Spacing="16">
                    <ProgressRing x:Name="LoadingRing" IsActive="True" Width="48" Height="48"/>
                    <TextBlock x:Name="LoadingMessage"
                              Text="Loading episodes..."
                              Style="{ThemeResource BodyTextBlockStyle}"
                              HorizontalAlignment="Center"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- Episodes ListView -->
                <ListView x:Name="EpisodesListView"
                         SelectionMode="Single"
                         Visibility="Collapsed"
                         SelectionChanged="EpisodesListView_SelectionChanged"
                         Padding="16,0,16,8">

                    <ListView.ItemContainerTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True"/>
                            <RepositionThemeTransition/>
                        </TransitionCollection>
                    </ListView.ItemContainerTransitions>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Play Episode"
                                                       Click="PlayMenuItem_Click"
                                                       Tag="{Binding}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE768;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="Download Episode"
                                                       Click="DownloadMenuItem_Click"
                                                       Tag="{Binding}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE896;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>

                                <!-- Episode image -->
                                <Border Grid.Column="0" CornerRadius="6"
                                       Width="48" Height="48"
                                       Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                </Border>

                                <!-- Episode details -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                    <TextBlock Text="{Binding Title}"
                                              Style="{ThemeResource BodyStrongTextBlockStyle}"
                                              MaxLines="1"
                                              TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding MetadataLine}"
                                              Style="{ThemeResource CaptionTextBlockStyle}"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Description}"
                                              Style="{ThemeResource CaptionTextBlockStyle}"
                                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                              MaxLines="1"
                                              TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Play button -->
                                <Button Grid.Column="2"
                                       Click="PlayButton_Click"
                                       Tag="{Binding}"
                                       Style="{ThemeResource AccentButtonStyle}"
                                       Width="32" Height="32"
                                       CornerRadius="16"
                                       Padding="0"
                                       VerticalAlignment="Center"
                                       ToolTipService.ToolTip="Play">
                                    <FontIcon Glyph="&#xE768;" FontSize="12"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <!-- ═══ Now Playing Bar ═══ -->
        <Grid Grid.Row="2"
              x:Name="MediaControlsPanel"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Seek Slider -->
            <Slider x:Name="SeekSlider"
                    Grid.Row="0"
                    Minimum="0" Maximum="100" Value="0"
                    Margin="12,4,12,-4"
                    ValueChanged="SeekSlider_ValueChanged"/>

            <!-- Transport Controls -->
            <Grid Grid.Row="1" Padding="16,4,16,12" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Album Art -->
                <Border Grid.Column="0" CornerRadius="4"
                       Width="40" Height="40"
                       Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Image x:Name="CurrentEpisodeImage" Stretch="UniformToFill"/>
                </Border>

                <!-- Episode Info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="CurrentEpisodeTitle"
                              Style="{ThemeResource BodyStrongTextBlockStyle}"
                              TextTrimming="CharacterEllipsis"
                              MaxLines="1"/>
                    <TextBlock x:Name="PlaybackStatusText"
                              Style="{ThemeResource CaptionTextBlockStyle}"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- Playback Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                           Spacing="4" VerticalAlignment="Center">
                    <Button x:Name="StopButton"
                           Click="StopButton_Click"
                           Width="32" Height="32" Padding="0"
                           Background="Transparent" BorderBrush="Transparent"
                           ToolTipService.ToolTip="Stop">
                        <FontIcon Glyph="&#xE71A;" FontSize="14"/>
                    </Button>
                    <Button x:Name="PlayPauseButton"
                           Click="PlayPauseButton_Click"
                           Style="{ThemeResource AccentButtonStyle}"
                           Width="36" Height="36"
                           CornerRadius="18"
                           Padding="0"
                           ToolTipService.ToolTip="Play / Pause">
                        <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="16"/>
                    </Button>
                </StackPanel>

                <!-- Time Display -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                           VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="PositionText"
                              Style="{ThemeResource CaptionTextBlockStyle}"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              MinWidth="36" TextAlignment="Right"/>
                    <TextBlock Text="/"
                              Style="{ThemeResource CaptionTextBlockStyle}"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock x:Name="DurationText"
                              Style="{ThemeResource CaptionTextBlockStyle}"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              MinWidth="36"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
