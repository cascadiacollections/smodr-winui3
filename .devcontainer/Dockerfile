# Official MSFT verified devcontainer base — Ubuntu 24.04 LTS (Noble)
# Includes: git, gh, zsh, oh-my-zsh, non-root vscode user
# ~300MB slimmer than building on dotnet/sdk with manual apt-get installs
FROM mcr.microsoft.com/devcontainers/base:noble

ENV DOTNET_CLI_TELEMETRY_OPTOUT=1 \
    DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1 \
    DOTNET_NOLOGO=1 \
    NUGET_XMLDOC_MODE=skip

